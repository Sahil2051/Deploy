# PostgreSQL — use DATABASE_URL on Render (from the Postgres add-on), or set PG_* for local dev
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: local Postgres without DATABASE_URL
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your-password
# PG_DATABASE=shelter_auth

# Set when your DB requires SSL (Render external URL often includes sslmode=require)
# PGSSLMODE=require
# DATABASE_SSL=true

APP_PORT=5000
APP_HOST=0.0.0.0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=SHELTER <your-smtp-user@gmail.com>
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173
